		{
			"name": "Plots - Retrieve",
			"item": [
				{
					"name": "Get All Plots",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response is an array\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(Array.isArray(jsonData)).to.be.true;",
									"});",
									"",
									"pm.test(\"Response contains at least one plot\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.length).to.be.at.least(1);",
									"});",
									"",
									"pm.test(\"Response time is acceptable\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(1000);",
									"});",
									"",
									"// Verify plot structure",
									"if (pm.response.json().length > 0) {",
									"    var firstPlot = pm.response.json()[0];",
									"    ",
									"    pm.test(\"Plot has required fields\", function () {",
									"        pm.expect(firstPlot).to.have.property('_id');",
									"        pm.expect(firstPlot).to.have.property('plot_number');",
									"        pm.expect(firstPlot).to.have.property('price');",
									"        pm.expect(firstPlot).to.have.property('status');",
									"        pm.expect(firstPlot).to.have.property('type');",
									"        pm.expect(firstPlot).to.have.property('societyId');",
									"    });",
									"    ",
									"    // Check if our newly created plot is in the list",
									"    var plotFound = false;",
									"    var plots = pm.response.json();",
									"    ",
									"    for (var i = 0; i < plots.length; i++) {",
									"        if (plots[i]._id === pm.environment.get(\"plot_id\")) {",
									"            plotFound = true;",
									"            break;",
									"        }",
									"    }",
									"    ",
									"    pm.test(\"Newly created plot is in the list\", function() {",
									"        pm.expect(plotFound).to.be.true;",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "http://localhost:5000/api/plots",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "5000",
							"path": [
								"api",
								"plots"
							]
						},
						"description": "Retrieve all plots for the current user's society."
					}
				},
				{
					"name": "Get Single Plot",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response contains correct plot\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData._id).to.eql(pm.environment.get(\"plot_id\"));",
									"    pm.expect(jsonData.plot_number).to.eql(pm.environment.get(\"random_plot_number\"));",
									"});",
									"",
									"pm.test(\"Plot has description array\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.description).to.be.an('array');",
									"    pm.expect(jsonData.description.length).to.be.at.least(1);",
									"});",
									"",
									"pm.test(\"Plot has amenities array\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.amenities).to.be.an('array');",
									"    pm.expect(jsonData.amenities.length).to.be.at.least(1);",
									"});",
									"",
									"pm.test(\"Plot has image data\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.image).to.be.a('string');",
									"    pm.expect(jsonData.image.length).to.be.above(20);  // Should be a data URL or path",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
