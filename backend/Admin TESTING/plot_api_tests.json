		{
			"name": "Authentication",
			"item": [
				{
					"name": "Society Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response contains access token\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.access_token).to.not.be.undefined;",
									"    ",
									"    // Store the access token for subsequent requests",
									"    pm.environment.set(\"access_token\", jsonData.access_token);",
									"});",
									"",
									"pm.test(\"User is a society admin\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.user.role).to.eql(\"society\");",
									"    ",
									"    // Store user information for later tests",
									"    pm.environment.set(\"user_email\", jsonData.user.email);",
									"    pm.environment.set(\"user_role\", jsonData.user.role);",
									"});",
									""
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"abcf@example.com\",\n  \"password\": \"abcf@example.com\"\n}"
						},
						"url": {
							"raw": "http://localhost:5000/api/login",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "5000",
							"path": [
								"api",
								"login"
							]
						},
						"description": "Login to get the authentication token for subsequent API calls. This test uses the society account."
					}
				}
			]
		},
