              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response contains plots array\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.plots).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"Created plot is in the list\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var found = false;",
                  "    ",
                  "    jsonData.plots.forEach(function(plot) {",
                  "        if (plot.plot_number === pm.environment.get(\"random_plot_number\")) {",
                  "            found = true;",
                  "            return;",
                  "        }",
                  "    });",
                  "    ",
                  "    pm.expect(found).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
