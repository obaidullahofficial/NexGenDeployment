{
  "info": {
    "name": "NextGenArchitect Plot API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Tests for the plot API endpoints in the NextGenArchitect application"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Society Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"abcf@example.com\",\n    \"password\": \"abcf@example.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/society/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "society", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response contains access token\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.access_token).to.exist;",
                  "    pm.environment.set(\"access_token\", jsonData.access_token);",
                  "});",
                  "",
                  "// Generate a random plot number for use in tests",
                  "var randomPlotNumber = \"Plot-\" + Math.floor(Math.random() * 100000);",
                  "pm.environment.set(\"random_plot_number\", randomPlotNumber);",
                  "",
                  "// Set values for update tests",
                  "pm.environment.set(\"updated_price\", \"5200000\");",
                  "pm.environment.set(\"updated_description\", \"Updated luxury plot with great views\");"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Create Plot Tests",
      "item": [
        {
          "name": "Create Plot - Valid Data",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "plot_number",
                  "value": "{{random_plot_number}}",
                  "type": "text"
                },
                {
                  "key": "area",
                  "value": "1200",
                  "type": "text"
                },
                {
                  "key": "price",
                  "value": "4800000",
                  "type": "text"
                },
                {
                  "key": "status",
                  "value": "Available",
                  "type": "text"
                },
                {
                  "key": "location",
                  "value": "North Block",
                  "type": "text"
                },
                {
                  "key": "length",
                  "value": "40",
                  "type": "text"
                },
                {
                  "key": "width",
                  "value": "30",
                  "type": "text"
                },
                {
                  "key": "description[]",
                  "value": "",
                  "type": "text"
                },
                {
                  "key": "description[0]",
                  "value": "Spacious plot in a prime location",
                  "type": "text"
                },
                {
                  "key": "description[1]",
                  "value": "Perfect for building your dream home",
                  "type": "text"
                },
                {
                  "key": "description[2]",
                  "value": "Close to amenities and schools",
                  "type": "text"
                },
                {
                  "key": "amenities[]",
                  "value": "",
                  "type": "text"
                },
                {
                  "key": "amenities[0]",
                  "value": "24/7 Security",
                  "type": "text"
                },
                {
                  "key": "amenities[1]",
                  "value": "Park Access",
                  "type": "text"
                },
                {
                  "key": "amenities[2]",
                  "value": "Underground Utilities",
                  "type": "text"
                },
                {
                  "key": "plot_image",
                  "type": "file",
                  "src": "/path/to/plot-image.jpg"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:5000/api/plots",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "plots"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response contains plot details\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.plot).to.exist;",
                  "    pm.expect(jsonData.plot._id).to.exist;",
                  "    pm.environment.set(\"plot_id\", jsonData.plot._id);",
                  "    pm.expect(jsonData.plot.plot_number).to.eql(pm.environment.get(\"random_plot_number\"));",
                  "});",
                  "",
                  "pm.test(\"Description array is saved correctly\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.plot.description).to.be.an('array').that.includes(\"Spacious plot in a prime location\");",
                  "    pm.expect(jsonData.plot.description).to.have.lengthOf(3);",
                  "});",
                  "",
                  "pm.test(\"Amenities array is saved correctly\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.plot.amenities).to.be.an('array').that.includes(\"24/7 Security\");",
                  "    pm.expect(jsonData.plot.amenities).to.have.lengthOf(3);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
